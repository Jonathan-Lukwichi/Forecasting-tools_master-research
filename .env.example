# ============================================================================
# HealthForecast AI — Environment Variables Template
# Copy to .env and fill in your values: cp .env.example .env
# NEVER commit .env to git (it is in .gitignore)
# ============================================================================

# ---------- API Server ----------
SECRET_KEY=change-me-to-a-random-string-use-openssl-rand-hex-32
DEBUG=false
APP_VERSION=1.0.0

# ---------- Supabase (PostgreSQL + Auth + Storage) ----------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ---------- Local PostgreSQL (Docker Compose dev only) ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/healthforecast

# ---------- Redis (Celery broker + cache) ----------
REDIS_URL=redis://localhost:6379/0

# ---------- LLM APIs ----------
LLM_PROVIDER=anthropic
LLM_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ---------- File Uploads ----------
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=uploads

# ---------- Frontend (Next.js public vars — prefixed with NEXT_PUBLIC_) ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ---------- Deployment (set in cloud platform, not locally) ----------
# VERCEL_URL=your-app.vercel.app
# RAILWAY_URL=your-api.railway.app
# SENTRY_DSN=https://your-sentry-dsn
